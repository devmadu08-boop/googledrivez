# Fine-grained GitHub token with Contents: Read and write access to one repository.
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repository-name
GITHUB_BRANCH=main

# Upstash Redis integration values, automatically added by Vercel Marketplace.
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
# Vercel's Upstash integration may inject these equivalent names instead:
KV_REST_API_URL=https://your-database.upstash.io
KV_REST_API_TOKEN=your_upstash_token

# Keep these server-side only. Use a long, random session secret.
ADMIN_PASSWORD=choose-a-strong-admin-password
ADMIN_SESSION_SECRET=generate-a-long-random-secret
