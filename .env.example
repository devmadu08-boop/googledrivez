# Fine-grained GitHub token with Contents: Read and write access to one repository.
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repository-name
GITHUB_BRANCH=main

# Firebase Admin service-account values. Keep all three server-side only.
FIREBASE_PROJECT_ID=email-tr
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@email-tr.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Keep these server-side only. Use a long, random session secret.
ADMIN_PASSWORD=choose-a-strong-admin-password
ADMIN_SESSION_SECRET=generate-a-long-random-secret
